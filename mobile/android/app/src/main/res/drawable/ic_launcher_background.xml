<?xml version="1.0" encoding="utf-8"?>
<!-- full-bleed purple gradient: fills the whole adaptive-icon canvas so any
     launcher mask (circle, squircle, rounded-square) shows a solid icon with
     no gaps around the mark. Colours match the kunai tile gradient. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0"
                android:startY="0"
                android:endX="108"
                android:endY="108">
                <item android:offset="0" android:color="#FF7D6DEF" />
                <item android:offset="1" android:color="#FF5D4CCF" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
